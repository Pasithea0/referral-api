## DATABASE
DATABASE_URL=postgres://user:password@localhost:5432/referral_db?sslmode=disable

## ADMIN PASSWORD — used to access the /admin dashboard
ADMIN_PASSWORD=change-me

## SERVER
PORT=8081

## CORS — comma-separated origins allowed to call the API (webhook endpoint)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://theintrodb.org
